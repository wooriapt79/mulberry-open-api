{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mulberry.example/schema/luna-event-v1.json",
  "title": "Mulberry Luna Common Event",
  "description": "Mulberry Worker Network 표준 이벤트 스키마 v1.0 — CSA Kbin 검토 반영 (2026-07-18)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "task_id",
    "timestamp",
    "channel",
    "agent",
    "event_type",
    "status",
    "input_summary"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0",
      "description": "스키마 버전 — Schema Migration을 위해 required 필드로 지정"
    },
    "event_id": {
      "type": "string",
      "minLength": 8,
      "description": "이벤트 고유 ID (예: EVT-20260718-000001)"
    },
    "task_id": {
      "type": "string",
      "minLength": 8,
      "description": "연관 태스크 ID — 멀티 Agent 체인 추적용"
    },
    "parent_event_id": {
      "type": ["string", "null"],
      "description": "상위 이벤트 ID — handoff 체인 구성 시 사용"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 형식 (예: 2026-07-18T21:10:00+09:00)"
    },
    "channel": {
      "type": "string",
      "enum": ["kakao", "cowork", "search", "web", "api", "internal"],
      "description": "수신 채널. agent=human이면 기본 internal 권장 (카카오 직접 상담 시 kakao 허용)"
    },
    "agent": {
      "type": "string",
      "enum": ["kakao_luna", "search_luna", "cowork_luna", "gateway", "human"],
      "description": "처리 주체 Agent"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "message_received",
        "intent_detected",
        "search_requested",
        "search_completed",
        "handoff_requested",
        "human_approval_requested",
        "human_approval_received",
        "response_generated",
        "response_sent",
        "feedback_received",
        "error",
        "task_completed"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "received",
        "processing",
        "success",
        "partial",
        "failed",
        "refused",
        "escalated",
        "completed"
      ]
    },
    "session_id": { "type": ["string", "null"], "description": "채널 세션 추적 ID" },
    "user_ref": { "type": ["string", "null"], "description": "사용자 참조 ID — 원문 대신 해시 또는 내부 ID 사용 (개인정보 최소화)" },
    "intent": { "type": ["string", "null"], "description": "감지된 사용자 의도 (예: product_inquiry, coop_request)" },
    "input_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000,
      "description": "입력 요약 (개인정보 최소화 후). v1.1에서 raw_input 분리 + 4096자 확대 예정"
    },
    "output_summary": { "type": ["string", "null"], "maxLength": 2000, "description": "출력 요약. v1.1에서 4096자 확대 예정" },
    "tool": { "type": ["string", "null"], "description": "사용된 도구명" },
    "next_agent": {
      "type": ["string", "null"],
      "enum": ["kakao_luna", "search_luna", "cowork_luna", "human", null],
      "description": "다음 처리 Agent — handoff_requested 이벤트에서 사용"
    },
    "failure_code": {
      "type": ["string", "null"],
      "enum": ["SEARCH_NO_RESULT","SEARCH_REFUSAL","SOURCE_CONFLICT","TOOL_LIMIT","USER_INFO_MISSING","HUMAN_REQUIRED","PLATFORM_ERROR","TIMEOUT",null],
      "description": "실패 코드. v1.1에서 failure_category + failure_code 2단계로 확장 예정"
    },
    "human_approval_required": { "type": "boolean", "default": false, "description": "사람 승인 필요 여부 (결제·계약·환불 등)" },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "플랫폼별 확장 데이터",
      "properties": {
        "locale": { "type": "string", "description": "예: ko-KR, en-US" },
        "source_message_type": { "type": "string", "description": "예: text, image, button, file" },
        "platform_version": { "type": "string" },
        "client": { "type": "string", "description": "예: kakao-openbuilder, cowork-desktop" },
        "message_length": { "type": "integer" },
        "attachments": { "type": "integer" },
        "response_time_ms": { "type": "integer" },
        "retry_count": { "type": "integer" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "language": { "type": "string", "description": "예: ko, vi, id" },
        "timezone": { "type": "string", "description": "예: Asia/Seoul" },
        "model": { "type": "string" },
        "adapter_version": { "type": "string" }
      }
    }
  }
}
