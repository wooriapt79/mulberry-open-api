# Mulberry Mission Control — 환경변수 템플릿
# 실제 값은 .env(gitignore 처리됨) 또는 Railway Variables에 설정.
# 이 파일은 어떤 키가 필요한지 보여주는 용도 — 실제 시크릿 값을 넣지 마세요.

# --- 서버 ---
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# --- MongoDB ---
MONGODB_URI=

# --- Redis ---
REDIS_URL=
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# --- 인증 ---
# 필수. 미설정 시 서버가 기동되지 않음 (utils/jwt.js fail-fast, Issue #49)
JWT_SECRET=

# --- 외부 연동 ---
AGENCY_AGENTS_URL=
# Co-op Buy Boltzmann Engine (Python/FastAPI — 별도 Railway 서비스)
# 미설정 시 Mock 모드로 동작 (Week 1~2 개발 지원)
BOLTZMANN_URL=
AGENCY_AGENTS_TIMEOUT_MS=3000
GEMINI_API_KEY=

# --- 기타 서비스 API (모듈 상태 표시용) ---
PASSPORT_API_URL=
PAYMENT_API_URL=
SENSOR_API_URL=
RECOVERY_API_URL=
